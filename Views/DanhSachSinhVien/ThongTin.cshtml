@model List<WebTuyenSinh.Models.ThongTinSinhVien>

@{
    ViewData["Title"] = "Thông tin sinh viên";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<link rel="stylesheet" href="~/css/DanhSachTaiKhoanSinhVien.css" />

<!-- Navbar -->
<nav class="main-navbar">
    <a href="/DanhSachSinhVien/Index">Danh sách tài khoản</a>
    <a href="/DanhSachSinhVien/ThongTin" class="active">Thông tin sinh viên</a>
    <a href="/DanhSachSinhVien/DiemHB">Thông tin xét tuyển</a>
    <a href="/DanhSachSinhVien/NguyenVong">Nguyện vọng sinh viên</a>
</nav>

<h2 class="text-center text-primary mb-4">📋 Thông tin sinh viên</h2>

@if (TempData["ThongBao"] != null)
{
    <div class="alert alert-success text-center">@TempData["ThongBao"]</div>
}

<!-- Toolbar -->
<div class="action-bar mb-3">
    <form method="get" asp-action="ThongTin" class="search-form">
        <input type="text" name="tuKhoa" value="@ViewBag.TuKhoa" class="search-input" placeholder="🔍 Tìm theo CCCD hoặc nơi cấp..." />
        <button type="submit" class="btn-search">Tìm kiếm</button>
    </form>

    <a href="/DanhSachSinhVien/ThemThongTin" class="btn-action btn-primary">➕ Thêm mới</a>
    <a href="/DanhSachSinhVien/XuatExcelThongTin" class="btn-action btn-outline-success">📥 Xuất Excel</a>
    <a href="/DanhSachSinhVien/XuatPDFThongTin" target="_blank" class="btn-action btn-outline-info">📄 Xuất PDF</a>
    <button type="button" class="btn-action btn-outline-dark" onclick="printTable()">🖨️ In bảng</button>
</div>

<form id="form-xoa" method="post">
    <div class="bang-sinh-vien-wrapper">
        <table class="table table-bordered table-striped">
            <thead class="table-dark">
                <tr class="text-center">
                    <th><input type="checkbox" onclick="toggleAll(this)" /></th>
                    <th>CCCD</th>
                    <th>Dân tộc</th>
                    <th>Tôn giáo</th>
                    <th>Nơi cấp</th>
                    <th>Ngày cấp</th>
                    <th>Ngày hết hạn</th>
                    <th>Ảnh cá nhân</th>
                    <th>CCCD mặt trước</th>
                    <th>CCCD mặt sau</th>
                    <th>Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td><input type="checkbox" name="chonThongTin" value="@item.CCCD" /></td>
                            <td>@item.CCCD</td>
                            <td>@item.DanToc</td>
                            <td>@item.TonGiao</td>
                            <td>@item.NoiCap</td>
                            <td>@item.NgayCap</td>
                            <td>@item.NgayHetHan</td>
                            <td class="text-center">
                                @if (!string.IsNullOrEmpty(item.AnhCaNhanBase64))
                                {
                                    <img src="@item.AnhCaNhanBase64" class="img-preview" alt="Ảnh cá nhân" />
                                }
                            </td>
                            <td class="text-center">
                                @if (!string.IsNullOrEmpty(item.AnhCCCDMatTruocBase64))
                                {
                                    <img src="@item.AnhCCCDMatTruocBase64" class="img-preview" alt="CCCD Trước" />
                                }
                            </td>
                            <td class="text-center">
                                @if (!string.IsNullOrEmpty(item.AnhCCCDMatSauBase64))
                                {
                                    <img src="@item.AnhCCCDMatSauBase64" class="img-preview" alt="CCCD Sau" />
                                }
                            </td>
                            <td class="text-center">
                                <a class="btn btn-sm btn-warning"
                                   href="@Url.Action("SuaThongTin", "DanhSachSinhVien", new { id = item.CCCD })">
                                    ✏️ Sửa
                                </a>

                                <a class="btn btn-sm btn-danger"
                                   href="@Url.Action("XoaThongTin", "DanhSachSinhVien", new { id = item.CCCD })"
                                   onclick="return confirm('Xác nhận xóa thông tin này?')">
                                    🗑️ Xóa
                                </a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="11" class="text-center text-muted">Không có dữ liệu sinh viên.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</form>

@section Scripts {
    <script src="~/js/DanhSachTaiKhoanSinhVien.js"></script>
}

