@model List<WebTuyenSinh.Models.SinhVien>

@{
    ViewData["Title"] = "Danh sách tài khoản sinh viên";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<link rel="stylesheet" href="~/css/DanhSachTaiKhoanSinhVien.css" />

<!-- Navbar -->
<nav class="main-navbar">
    <a href="/DanhSachSinhVien/Index" class="active">Danh sách tài khoản</a>
    <a href="/DanhSachSinhVien/ThongTin">Thông tin sinh viên</a>
    <a href="/DanhSachSinhVien/DiemHB">Thông tin xét tuyển</a>
    <a href="/DanhSachSinhVien/NguyenVong">Nguyện vọng sinh viên</a>
</nav>

<h2 class="text-center text-primary mb-4">📋 Danh sách tài khoản sinh viên</h2>

@if (TempData["ThongBao"] != null)
{
        <div class="alert alert-success text-center">@TempData["ThongBao"]</div>
}

<!-- Toolbar -->
<div class="action-bar">
    <form method="get" asp-action="Index" class="search-form">
        <input type="text" name="tuKhoa" value="@ViewBag.TuKhoa" class="search-input" placeholder="🔍 Tìm theo tên hoặc CCCD..." />
        <button type="submit" class="btn-search">Tìm kiếm</button>
    </form>

    <a href="/DanhSachSinhVien/ThemMoi" class="btn-action btn-primary">➕ Thêm mới</a>
    <a href="/DanhSachSinhVien/XuatExcel" class="btn-action btn-outline-success">📥 Xuất Excel</a>
    <a href="/DanhSachSinhVien/XuatPDF" target="_blank" class="btn-action btn-outline-info">📄 Xuất PDF</a>
    <button type="button" class="btn-action btn-outline-dark" onclick="printTable()">🖨️ In bảng</button>
</div>

<!-- Bảng danh sách -->
<form id="form-xoa" method="post">
    <div class="bang-sinh-vien-wrapper">
        <table class="table table-bordered table-striped">
            <thead class="table-dark">
                <tr class="text-center">
                    <th><input type="checkbox" onclick="toggleAll(this)" /></th>
                    <th>CCCD</th>
                    <th>Họ tên</th>
                    <th>Ngày sinh</th>
                    <th>Giới tính</th>
                    <th>Email</th>
                    <th>SĐT</th>
                    <th>Số nhà</th>
                    <th>Phường/Xã</th>
                    <th>Quận/Huyện</th>
                    <th>Tỉnh/Thành</th>
                    <th>Vai trò</th>
                    <th>Ngày đăng ký</th>
                    <th>Trạng thái</th>
                    <th>Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                                <tr>
                                    <td><input type="checkbox" name="chonSinhVien" value="@item.CCCD" /></td>
                                    <td>@item.CCCD</td>
                                    <td>@item.HoTen</td>
                                    <td>@item.NgaySinh</td>
                                    <td>@item.GioiTinh</td>
                                    <td>@item.Email</td>
                                    <td>@item.SoDienThoai</td>
                                    <td>@item.SoNha</td>
                                    <td>@item.Ten_Phuong_Xa</td>
                                    <td>@item.Ten_Quan_Huyen</td>
                                    <td>@item.Ten_Tinh_Thanh</td>
                                    <td>@item.VaiTro</td>
                                    <td>@item.NgayDangKy</td>
                                    <td>@item.TrangThai</td>
                                    <td>
                                        <a class="btn btn-sm btn-warning"
                                           href="@Url.Action("Sua", "DanhSachSinhVien", new { id = item.CCCD })">
                                            ✏️ Sửa
                                        </a>

                                        <a class="btn btn-sm btn-danger"
                                           href="@Url.Action("Xoa", "DanhSachSinhVien", new { id = item.CCCD })"
                                           onclick="return confirm('Xác nhận xóa sinh viên này?')">
                                            🗑️ Xóa
                                        </a>
                                    </td>
                                </tr>
                    }
                }
                else
                {
                        <tr>
                            <td colspan="12" class="text-center text-muted">Không có dữ liệu sinh viên.</td>
                        </tr>
                }
            </tbody>
        </table>
    </div>
</form>

@section Scripts {
        <script src="~/js/DanhSachTaiKhoanSinhVien.js"></script>
}
