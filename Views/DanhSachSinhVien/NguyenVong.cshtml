@model List<WebTuyenSinh.Models.DangKyNguyenVong>

@{
    ViewData["Title"] = "Nguyện vọng sinh viên";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<link rel="stylesheet" href="~/css/DanhSachTaiKhoanSinhVien.css" />

<!-- Navbar -->
<nav class="main-navbar">
    <a href="/DanhSachSinhVien/Index">Danh sách tài khoản</a>
    <a href="/DanhSachSinhVien/ThongTin">Thông tin sinh viên</a>
    <a href="/DanhSachSinhVien/DiemHB">Thông tin xét tuyển</a>
    <a href="/DanhSachSinhVien/NguyenVong" class="active">Nguyện vọng sinh viên</a>
</nav>

<h2 class="text-center text-primary mb-4">📋 Danh sách nguyện vọng sinh viên</h2>

@if (TempData["ThongBao"] != null)
{
    <div class="alert alert-success text-center">@TempData["ThongBao"]</div>
}

<!-- Toolbar -->
<div class="action-bar">
    <form method="get" asp-action="NguyenVong" class="search-form">
        <input type="text" name="tuKhoa" value="@ViewBag.TuKhoa" class="search-input" placeholder="🔍 Tìm theo CCCD..." />
        <button type="submit" class="btn-search">Tìm kiếm</button>
    </form>

    <a href="/DanhSachSinhVien/ThemNguyenVong" class="btn-action btn-primary">➕ Thêm mới</a>
    <a href="/DanhSachSinhVien/XuatExcelNguyenVong" class="btn-action btn-outline-success">📥 Xuất Excel</a>
    <a href="/DanhSachSinhVien/XuatPDFNguyenVong" target="_blank" class="btn-action btn-outline-info">📄 Xuất PDF</a>
    <button type="button" class="btn-action btn-outline-dark" onclick="printTable()">🖨️ In bảng</button>
</div>

<!-- Bảng nguyện vọng -->
<form id="form-xoa" method="post">
    <div class="bang-sinh-vien-wrapper">
        <table class="table table-bordered table-striped" id="nguyenVongTable">
            <thead class="table-dark">
                <tr class="text-center">
                    <th><input type="checkbox" onclick="toggleAll(this)" /></th>
                    <th>CCCD</th>
                    @for (int i = 1; i <= 7; i++)
                    {
                        <th>NV @i</th>
                        <th>Mã nghề @i</th>
                        <th>Trạng thái @i</th>
                    }
                    <th>Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td><input type="checkbox" name="chonNguyenVong" value="@item.CCCD" /></td>
                            <td>@item.CCCD</td>

                            <td>@item.TenNghe1</td>
                            <td>@item.MaNghe1</td>
                            <td>@item.TrangThai1</td>

                            <td>@item.TenNghe2</td>
                            <td>@item.MaNghe2</td>
                            <td>@item.TrangThai2</td>

                            <td>@item.TenNghe3</td>
                            <td>@item.MaNghe3</td>
                            <td>@item.TrangThai3</td>

                            <td>@item.TenNghe4</td>
                            <td>@item.MaNghe4</td>
                            <td>@item.TrangThai4</td>

                            <td>@item.TenNghe5</td>
                            <td>@item.MaNghe5</td>
                            <td>@item.TrangThai5</td>

                            <td>@item.TenNghe6</td>
                            <td>@item.MaNghe6</td>
                            <td>@item.TrangThai6</td>

                            <td>@item.TenNghe7</td>
                            <td>@item.MaNghe7</td>
                            <td>@item.TrangThai7</td>

                            <td class="text-center">
                                <a class="btn btn-sm btn-warning"
                                   href="@Url.Action("SuaNguyenVong", "DanhSachSinhVien", new { id = item.CCCD })">
                                    ✏️ Sửa
                                </a>

                                <a class="btn btn-sm btn-danger"
                                   href="@Url.Action("XoaNguyenVong", "DanhSachSinhVien", new { id = item.CCCD })"
                                   onclick="return confirm('Xác nhận xóa nguyện vọng sinh viên này?')">
                                    🗑️ Xóa
                                </a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="30" class="text-center text-muted">Không có dữ liệu nguyện vọng.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</form>

@section Scripts {
    <script src="~/js/DanhSachTaiKhoanSinhVien.js"></script>
}
