                </div>
                <div class="slider-item">
                    <img src="https://scontent.fhan17-1.fna.fbcdn.net/v/t39.30808-6/494663527_1247927667332858_8954663652436819020_n.jpg?_nc_cat=108&ccb=1-7&_nc_sid=127cfc&_nc_eui2=AeGz0YTeAmt7Cu_FotqpxH9Hns1d_MGgtA2ezV38waC0DYLUL7JD2IyV3bu81zbMGMrkKVJOvNlKVmtb_WPXs-GX&_nc_ohc=xBCnKcW4MRMQ7kNvwEJZHhM&_nc_oc=Admj7zahjabikvZMiZizyseBR6_Ju9ec108wJOxpWq5rJ4t-TIvdEjhD3pwEZr_2ncM&_nc_zt=23&_nc_ht=scontent.fhan17-1.fna&_nc_gid=wsHjDd1-qJg09Q_U5rv54Q&oh=00_Afb3COEyXIVK5I2X95FaLDaskFpq7__-IXalZZFfE2xu7Q&oe=68C575A1" alt="Tình nguyện" />
