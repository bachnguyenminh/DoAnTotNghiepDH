@{
    ViewData["Title"] = "Xóa thông tin sinh viên";
}

<h2 class="text-danger text-center mt-4">❗ Xác nhận xóa thông tin sinh viên</h2>

<form asp-controller="Account" asp-action="XoaThongTinSinhVien" method="post"
      onsubmit="return confirm('Bạn có chắc chắn muốn xóa thông tin sinh viên?');">
    @Html.AntiForgeryToken()

    <div class="text-center mt-3 mb-4">
        <button type="submit" class="btn btn-danger">
            🗑️ Xác nhận xóa thông tin
        </button>

        <a href="@Url.Action("Login", "Account")" class="btn btn-secondary ms-3">
            ↩️ Quay lại
        </a>
    </div>
</form>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success text-center mt-3">@TempData["SuccessMessage"]</div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger text-center mt-3">@TempData["ErrorMessage"]</div>
}
